{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "uuid": { "type": "uid", "required": true },
    "name": { "type": "string" },
    "description": { "type": "richtext" },
    "price": { "type": "decimal" },
    "stock": { "type": "integer" },
    "image_url": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "category": { "type": "string" },
    "is_active": { "type": "boolean", "default": true }
  }
}
