{
  "kind": "collectionType",
  "collectionName": "payments",
  "info": {
    "singularName": "payment",
    "pluralName": "payments",
    "displayName": "Payment"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uuid": { "type": "uid", "required": true },
    "amount": { "type": "decimal" },
    "currency": { "type": "string", "default": "PEN" },
    "payment_method": { "type": "string" },
    "status": { "type": "string" },
    "transaction_id": { "type": "string" },
    "payment_reference": { "type": "text" },
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order.order",
      "mappedBy": "payment"
    }
  }
}
